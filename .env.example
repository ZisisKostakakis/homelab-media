# ==============================================
# HOMELAB MEDIA STACK - Environment Variables
# ==============================================
# Fill in the placeholder values below with your actual credentials

# ==============================================
# VPN Configuration (Gluetun + ProtonVPN)
# ==============================================

# Your WireGuard private key from ProtonVPN account
# Get this from: https://account.protonvpn.com/account#openvpn
WIREGUARD_PRIVATE_KEY=your_wireguard_private_key_here

# WireGuard IP address (usually 10.2.0.2/32 for ProtonVPN)
WIREGUARD_ADDRESSES=10.2.0.2/32

# ProtonVPN server location (e.g., London, Amsterdam, NewYork)
SERVER_CITIES=London

# Local network subnet for firewall rules
# Change this to match your local network (e.g., 192.168.1.0/24, 192.168.0.0/24, 10.0.0.0/24)
FIREWALL_OUTBOUND_SUBNETS=192.168.1.0/24

# ==============================================
# Service API Keys
# ==============================================

# Sonarr API Key
# Find in: Settings > General > Security > API Key
# Used by: Unpackerr, Recyclarr
SONARR_API_KEY=your_sonarr_api_key_here

# Radarr API Key
# Find in: Settings > General > Security > API Key
# Used by: Unpackerr, Recyclarr
RADARR_API_KEY=your_radarr_api_key_here

# Readarr API Key
# Find in: Settings > General > Security > API Key
# Used by: Unpackerr
READARR_API_KEY=your_readarr_api_key_here

# Plex Claim Token (expires after 4 minutes - generate when ready to deploy)
# Get from: https://www.plex.tv/claim/
# Only needed for initial Plex setup, can be removed after first run
PLEX_CLAIM=your_plex_claim_token_here

# ==============================================
# SuggestArr Configuration (Optional)
# ==============================================

# Port for SuggestArr service (default: 5000)
SUGGESTARR_PORT=5000

# Log level for SuggestArr (options: debug, info, warning, error)
LOG_LEVEL=info

# ==============================================
# Plex Monitoring & Management
# ==============================================

# Tautulli port (8181 used by filebrowser, 8182 used by wud-webhook)
TAUTULLI_PORT=8787

# Readarr host port (container port is always 8787)
# Using 8282 to avoid conflict with Tautulli which occupies host port 8787
READARR_PORT=8282

# ==============================================
# Kavita - Ebook/Comics Reader
# ==============================================

# Kavita host port (container port is always 5000)
# Using 5001 to avoid conflict with SuggestArr which occupies host port 5000
KAVITA_PORT=5001

# Kitana port (default: 31337)
KITANA_PORT=31337

# Kometa - Run mode (true for scheduled, false for manual via docker exec)
KOMETA_RUN=true

# Kometa - Scheduled run time (24h format, default: 05:00)
KOMETA_TIME=05:00

# ==============================================
# Common Settings
# ==============================================

# User/Group IDs for file permissions
# Use 'id' command to find your user's UID/GID
# Default: 1000 (common for first user on Linux systems)
PUID=1000
PGID=1000

# Timezone for most services
# Format: Continent/City (e.g., Europe/London, America/New_York, Asia/Tokyo)
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/London

# Timezone specifically for Maintainerr service
# Can be the same as TZ above or different if needed
TZ_MAINTAINERR=Europe/Belfast

# ==============================================
# Gluetun Monitor Configuration
# ==============================================

# Notification topic for Gluetun cascade restart events
# This is separate from WUD notifications
GLUETUN_MONITOR_NTFY_TOPIC=your_ntfy_topic_here

# ==============================================
# NOTES
# ==============================================
#
# 1. After filling in values, make sure .env is in .gitignore
# 2. Never commit .env with real credentials to version control
# 3. To apply changes: ./stack-manage.sh <stack> restart
# 4. Backup this file securely after configuration
# 5. Use the backup-config.sh script to backup all configurations
#
# SECRET EXPIRY REMINDERS:
#   - HARDCOVER_AUTH:    Expires January 1st each year — renew at hardcover.app
#   - PLEX_CLAIM:        Expires after 4 minutes — generate only when ready to deploy
#   - WIREGUARD_PRIVATE_KEY: Rotate if VPN account credentials change
#   - OPENAI/GEMINI/MISTRAL API keys: Check provider dashboard for expiry/quota
#

CROSS_SEED_API_KEY=your_cross_seed_api_key_here

BESZEL_AGENT_KEY=your_beszel_agent_ssh_public_key_here

TOKEN=your_token_here

QBITTORRENT_PASSWORD=your_qbittorrent_password_here

# ==============================================
# AudioMuse - AI Music Analysis (companion to Navidrome)
# ==============================================

# Host port for AudioMuse Web UI (default: 8000)
# Note: ensure portainer's 8000 edge agent port is commented out in docker-compose-services.yml
AUDIOMUSE_PORT=8000

# Navidrome credentials for AudioMuse to connect with
AUDIOMUSE_NAVIDROME_USER=your_navidrome_username_here
AUDIOMUSE_NAVIDROME_PASSWORD=your_navidrome_password_here

# AI provider selection: openai, gemini, or mistral
AUDIOMUSE_AI_MODEL_PROVIDER=openai

# OpenAI configuration (used when AI_MODEL_PROVIDER=openai)
# OPENAI_SERVER_URL can point to a local LLM server (e.g., Ollama) or left blank for OpenAI default
AUDIOMUSE_OPENAI_API_KEY=your_openai_api_key_here
AUDIOMUSE_OPENAI_SERVER_URL=https://api.openai.com/v1/chat/completions
AUDIOMUSE_OPENAI_MODEL_NAME=gpt-4o-mini

# Gemini configuration (used when AI_MODEL_PROVIDER=gemini)
AUDIOMUSE_GEMINI_API_KEY=your_gemini_api_key_here

# Mistral configuration (used when AI_MODEL_PROVIDER=mistral)
AUDIOMUSE_MISTRAL_API_KEY=your_mistral_api_key_here

# CLAP semantic text-to-audio search (resource-intensive; set false on slower systems)
AUDIOMUSE_CLAP_ENABLED=false

# AudioMuse internal database credentials (only used between audiomuse containers)
AUDIOMUSE_POSTGRES_USER=audiomuse
AUDIOMUSE_POSTGRES_PASSWORD=your_audiomuse_db_password_here
AUDIOMUSE_POSTGRES_DB=audiomuse

# =============================================================================
# WUD (What's Up Docker) Authentication
# Generate hash: htpasswd -nbB admin <your_password> | sed 's/admin://'
# Escape $ signs with $$ when used in docker-compose env values
# =============================================================================
WUD_AUTH_BASIC_ADMIN_HASH=your_bcrypt_hash_here

# =============================================================================
# NTFY Notification Topics
# =============================================================================
# WUD update notifications topic
WUD_NTFY_TOPIC=homelab-wud-docker-updates
# Gluetun cascade restart notifications topic
GLUETUN_NTFY_TOPIC=homelab-gluetun-cascade

# =============================================================================
# rreading-glasses (Hardcover metadata proxy for Readarr/Bookshelf)
# =============================================================================
# Hardcover API token - generate at: hardcover.app > Settings > Developer > API Token
# Must start with "Bearer " (include the space)
# EXPIRY: Hardcover tokens expire annually on January 1st — renew before that date
HARDCOVER_AUTH=Bearer your_hardcover_token_here
# Random password for the rreading-glasses internal database (no special characters)
RREADING_GLASSES_DB_PASSWORD=your_generated_password_here

# =============================================================================
# Books Stack (Suwayomi / Kavita)
# =============================================================================

# Suwayomi (Tachidesk) - Manga downloader web UI port (default: 4567)
SUWAYOMI_PORT=4567
